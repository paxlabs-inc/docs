    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "api": {
    "openapi": "/openapi.yaml",
    "playground": {
      "display": "interactive"
    }
  },
  "thumbnails": {
    "background": "/images/main.webp",
    "appearance": "dark"
  },
  "styling": {
    "eyebrows": "section"
  },
  "navbar": {
    "links": [
      {
        "label": "Developer Portal",
        "href": "https://build.hyperpaxeer.com/"
      },
      {
        "label": "Block Explorer",
        "href": "https://paxscan.io/"
      },
      {
        "label": "Whitepaper",
        "href": "http://whitepaper.paxeer.app/"
      }
    ]
