  "banner": {
    "content": "HyperPaxeer docs are live.",
    "dismissible": false
  },
  "favicon": "/images/sid-fun-icon(1).png",
  "logo": {
    "light": "/images/sid-fun-icon(1).png",
    "dark": "/images/sid-fun-icon2.png",
    "href": "/"
  },
  "background": {
    "image": "/images/main.webp"
  },
  "appearance": {
    "default": "dark"
